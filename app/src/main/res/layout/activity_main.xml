<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a1a"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="K.Proxy"
                android:textSize="32sp"
                android:textColor="#ff6b6b"
                android:gravity="center"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Advanced System Modifier v5.0"
                android:textSize="12sp"
                android:textColor="#666666"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtAntiBanStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🛡️ Anti-Ban: Active ✓"
                android:textSize="12sp"
                android:textColor="#00ff88"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/mainMenuLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="━━━ HEADSHOT FEATURES ━━━"
                    android:textSize="13sp"
                    android:textColor="#ff6b6b"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Headshot V5"
                    android:textSize="20sp"
                    android:textColor="#ffffff"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="HS Body (Extreme) • 80% Headshot"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="━━━ RISK FEATURES ━━━"
                    android:textSize="13sp"
                    android:textColor="#ff6b6b"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <CheckBox
                    android:id="@+id/chkSpeedHack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Speed Hack (3x)"
                    android:textColor="#e0e0e0"
                    android:buttonTint="#ff6b6b"
                    android:padding="8dp"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/chkHighJump"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="High Jump (3x)"
                    android:textColor="#e0e0e0"
                    android:buttonTint="#ff6b6b"
                    android:padding="8dp"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/chkHighSensitivity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="High Sensitivity (0-400)"
                    android:textColor="#e0e0e0"
                    android:buttonTint="#ff6b6b"
                    android:padding="8dp"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/chkFastSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fast Switch Weapon (3x)"
                    android:textColor="#e0e0e0"
                    android:buttonTint="#ff6b6b"
                    android:padding="8dp"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/chkHeadshotV5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Headshot V5 (80% Headshot)"
                    android:textColor="#00ff88"
                    android:buttonTint="#ff6b6b"
                    android:padding="8dp"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnInstall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CÀI ĐẶT"
                    android:background="#ff6b6b"
                    android:textColor="#ffffff"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="20dp"
                    android:padding="16dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/shizukuConnectLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="━━━ CONNECTION ━━━"
                    android:textSize="16sp"
                    android:textColor="#ffffff"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/txtShizukuStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔴 Disconnected"
                    android:textSize="18sp"
                    android:textColor="#ff6b6b"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connection type:"
                    android:textColor="#888888"
                    android:padding="4dp"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚡ Shizuku"
                    android:textColor="#00ff88"
                    android:padding="4dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="━━━ TUTORIAL ━━━"
                    android:textSize="14sp"
                    android:textColor="#ff6b6b"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Open Settings → Developer Options"
                    android:textColor="#e0e0e0"
                    android:padding="4dp"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2. Enable 'Wireless debugging'"
                    android:textColor="#e0e0e0"
                    android:padding="4dp"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3. Tap 'Pair device with pairing code'"
                    android:textColor="#e0e0e0"
                    android:padding="4dp"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="4. Enter pairing code below:"
                    android:textColor="#ffffff"
                    android:padding="4dp"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etPairingCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="6-digit pairing code"
                    android:inputType="number"
                    android:maxLength="6"
                    android:background="#1a1a3a"
                    android:textColor="#ffffff"
                    android:textColorHint="#666666"
                    android:padding="14dp"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnGeneratePairingCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Generate New Code"
                    android:background="#333355"
                    android:textColor="#ffffff"
                    android:padding="10dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnShizukuConnect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CONNECT"
                    android:background="#ff6b6b"
                    android:textColor="#ffffff"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:padding="16dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>